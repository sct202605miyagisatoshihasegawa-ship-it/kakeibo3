<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" 
xmlns:fx="http://javafx.com/fxml/1" 
fx:controller="com.kakeibo3.controller.KakeiboController">
    <fx:define>
        <ToggleGroup fx:id="tabGroup" />
    </fx:define>

    <!-- 上部メニュー -->
    <top>
        <HBox spacing="5">
            <padding>
                <Insets bottom="5" left="5" right="5" top="5" />
            </padding>
            <children>
            
            <ToggleButton fx:id="yearButton" text="年間" toggleGroup="$tabGroup"
                 />
            
                <ToggleButton fx:id="janButton" text="1月" toggleGroup="$tabGroup"
                 />
                <ToggleButton fx:id="febButton" text="2月" toggleGroup="$tabGroup" 
                />
                <ToggleButton fx:id="marButton" text="3月" toggleGroup="$tabGroup"
                 />
                <ToggleButton fx:id="aprButton" text="4月" toggleGroup="$tabGroup" 
                />
                <ToggleButton fx:id="mayButton" text="5月" toggleGroup="$tabGroup"
                 />
                <ToggleButton fx:id="junButton" text="6月" toggleGroup="$tabGroup" 
                />
                <ToggleButton fx:id="julButton" text="7月" toggleGroup="$tabGroup" 
                />
                <ToggleButton fx:id="augButton" text="8月" toggleGroup="$tabGroup" 
                />
                <ToggleButton fx:id="sepButton" text="9月" toggleGroup="$tabGroup" 
                />
                <ToggleButton fx:id="octButton" text="10月" toggleGroup="$tabGroup" 
                />
                <ToggleButton fx:id="novButton" text="11月" toggleGroup="$tabGroup" 
                />
                <ToggleButton fx:id="decButton" text="12月" toggleGroup="$tabGroup" 
                />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="saveButton" text="保存" />
                <Button fx:id="undoButton" text="戻る" />
            </children>
        </HBox>
    </top>

    <!-- 中央 -->
    <center>
        <SplitPane dividerPositions="0.80">
            <items>
                <!-- 左側：明細一覧 -->
                <VBox spacing="5">
                    <padding>
                        <Insets bottom="5" left="5" right="5" top="5" />
                    </padding>
                    <children>
                        <Label text="明細一覧" />
                        <TableView fx:id="transactionTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colDate" prefWidth="90" text="日付" />
                                <TableColumn fx:id="colAmount" prefWidth="100" text="金額" />
                                <TableColumn fx:id="colCategory" prefWidth="140" text="収支内訳" />
                                <TableColumn fx:id="colPaymentMethod" prefWidth="120" text="決済方法" />
                                <TableColumn fx:id="colDetail" prefWidth="300" text="詳細" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>

                <!-- 右側：収支内訳 -->
                <VBox spacing="5">
                    <padding>
                        <Insets bottom="5" left="5" right="5" top="5" />
                    </padding>
                    <children>
                        <Label fx:id="summaryTitleLabel" text="年間収支内訳" />
                        <ListView fx:id="categorySummaryList" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </center>

    <!-- 下部 -->
    <bottom>
        <VBox spacing="10">
            <padding>
                <Insets bottom="5" left="5" right="5" top="5" />
            </padding>
            <children>
                <!-- 口座残高 -->
                <TitledPane expanded="true" text="口座残高（参考）">
                    <content>
                        <GridPane hgap="15" vgap="5">
                            <children>
                                <Label text="銀行口座A" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                <Label fx:id="bankABalanceLabel"
       							text="0円"
       							GridPane.columnIndex="1"
       							GridPane.rowIndex="0" />
                                <Label text="銀行口座B" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                <Label fx:id="bankBBalanceLabel"
       							text="0円"
       							GridPane.columnIndex="1"
       							GridPane.rowIndex="1" />
                                <Label text="手元現金" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                <Label fx:id="cashBalanceLabel"
       							text="0円"
       							GridPane.columnIndex="1"
       							GridPane.rowIndex="2" />
                            </children>
                        </GridPane>
                    </content>
                </TitledPane>

                <!-- メモ -->
                <VBox spacing="5">
                    <children>
                        <Label text="メモ" />
                        <TextArea fx:id="memoArea" prefRowCount="4" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </bottom>
</BorderPane>
